# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (optional; defaults to sqlite:///db.sqlite3)
# DATABASE_URL=sqlite:///db.sqlite3

# WhatsApp / Meta API (optional; either token env name works)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# META_PHONE_NUMBER_ID=
# WHATSAPP_TEMPLATE_NAME=mp_request_v1
# WHATSAPP_BUYER_TEMPLATE_NAME=zpt_buyer_request_receipt
# WHATSAPP_TEMPLATE_LANG=ru
# Локаль должна совпадать с языком шаблона в WhatsApp Manager (ru, en, kk, en_US и т.д.)
# WHATSAPP_TEMPLATE_HAS_IMAGE_HEADER=false
# PUBLIC_BASE_URL=https://zpt.kz
# ORDER_ADMIN_EMAIL=

# SellerLead pipeline email notifications
# SELLER_PIPELINE_EMAIL_ENABLED=False
# SELLER_PIPELINE_NOTIFICATION_EMAIL=

# Seller lead search (Brave Search API)
# SELLER_SEARCH_PROVIDER=brave
# BRAVE_SEARCH_API_KEY=
# SELLER_SEARCH_ENABLED=False
